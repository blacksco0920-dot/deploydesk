{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ABCDeploy",
  "version": "0.2.0-preview.2",
  "identifier": "cloud.finagent.abcdeploy",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ABCDeploy 小白部署",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "面向编程新手的企业级部署工具",
    "longDescription": "自动识别项目并引导完成容器构建、测试环境、生产发布、HTTPS 和回滚。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
