{
  "name": "abcdeploy",
  "version": "0.2.0-preview.1",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "pnpm --filter @abcdeploy/desktop build",
    "dev": "pnpm --filter @abcdeploy/desktop tauri dev",
    "desktop": "pnpm --filter @abcdeploy/desktop",
    "format": "cargo fmt --all && pnpm --filter @abcdeploy/desktop format",
    "lint": "cargo clippy --workspace --all-targets -- -D warnings && pnpm --filter @abcdeploy/desktop lint",
    "test": "cargo test --workspace && pnpm --filter @abcdeploy/desktop test && node --test scripts/build-release-manifest.test.mjs",
    "site:build": "pnpm --filter @abcdeploy/site build",
    "site:dev": "pnpm --filter @abcdeploy/site dev",
    "tauri:build": "pnpm --filter @abcdeploy/desktop tauri build",
    "tauri:build:mac": "CI=true APPLE_SIGNING_IDENTITY=- pnpm --filter @abcdeploy/desktop tauri build --bundles app,dmg --ci"
  }
}
